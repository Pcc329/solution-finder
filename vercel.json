{
  "rewrites": [
    { "source": "/api/solutions", "destination": "/api/solutions" },
    { "source": "/api/stats", "destination": "/api/stats" },
    { "source": "/api/ask", "destination": "/api/ask" },
    { "source": "/api/cases", "destination": "/api/cases" },
    { "source": "/api/manufacturing-analyze", "destination": "/api/manufacturing-analyze" },
    { "source": "/api/manufacturing-recommend", "destination": "/api/manufacturing-recommend" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" }
      ]
    }
  ]
}
